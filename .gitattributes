# Keep text files stable across macOS, Linux, and Windows checkouts.
* text=auto eol=lf

# Binary/image data should never be newline-normalized.
*.bmp binary
*.gif binary
*.ico binary
*.jpg binary
*.jpeg binary
*.png binary
*.tif binary
*.tiff binary
*.ome.tif binary
*.ome.tiff binary
*.pdf binary
*.npy binary
*.npz binary
